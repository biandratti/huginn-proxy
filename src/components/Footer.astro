---
import EditLink from 'virtual:starlight/components/EditLink';
import LastUpdated from 'virtual:starlight/components/LastUpdated';
import Pagination from 'virtual:starlight/components/Pagination';
import config from 'virtual:starlight/user-config';
import { Icon } from '@astrojs/starlight/components';

const licenseBase = 'https://github.com/biandratti/huginn-proxy/blob/master';
---

<footer class="sl-flex">
	<div class="meta sl-flex">
		<EditLink />
		<LastUpdated />
	</div>
	<Pagination />

	<div class="attribution">
		<p class="attribution__line">Copyright © 2025–2026 Maximiliano Biandratti</p>
		<p class="attribution__line">
			Huginn Proxy is dual-licensed under the
			<a href={`${licenseBase}/LICENSE-MIT`}>MIT License</a>
			and the
			<a href={`${licenseBase}/LICENSE-APACHE`}>Apache License 2.0</a>.
		</p>
	</div>

	{
		config.credits && (
			<a class="kudos sl-flex" href="https://starlight.astro.build">
				<Icon name={'starlight'} /> {Astro.locals.t('builtWithStarlight.label')}
			</a>
		)
	}
</footer>

<style>
	@layer starlight.core {
		footer {
			flex-direction: column;
			gap: 1.5rem;
		}
		.meta {
			gap: 0.75rem 3rem;
			justify-content: space-between;
			flex-wrap: wrap;
			margin-top: 3rem;
			font-size: var(--sl-text-sm);
			color: var(--sl-color-gray-3);
		}
		.meta > :global(p:only-child) {
			margin-inline-start: auto;
		}

		.attribution {
			margin-block: 0.5rem 0;
			padding-block-start: 1rem;
			border-top: 1px solid var(--sl-color-hairline);
			font-size: var(--sl-text-sm);
			color: var(--sl-color-gray-3);
			text-align: center;
			line-height: 1.5;
		}

		.attribution__line {
			margin: 0;
		}

		.attribution__line + .attribution__line {
			margin-top: 0.35rem;
		}

		.attribution a {
			color: var(--sl-color-accent);
			text-decoration: underline;
			text-underline-offset: 0.12em;
		}

		.attribution a:hover {
			color: var(--sl-color-white);
		}

		.kudos {
			align-items: center;
			gap: 0.5em;
			margin: 1.5rem auto;
			font-size: var(--sl-text-xs);
			text-decoration: none;
			color: var(--sl-color-gray-3);
		}
		.kudos:hover {
			color: var(--sl-color-white);
		}
	}

	@layer starlight.components {
		.kudos :global(svg) {
			color: var(--sl-color-orange);
		}
	}
</style>
