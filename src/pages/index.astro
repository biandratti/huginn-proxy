---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import '../styles/landing.css';

const releasePath = join(process.cwd(), 'src/data/release-version.json');
const { tag: releaseTag } = JSON.parse(readFileSync(releasePath, 'utf8'));

const base = import.meta.env.BASE_URL;
const docs = `${base}docs/`;
const quickStart = `${base}docs/quick-example/`;
const github = 'https://github.com/biandratti/huginn-proxy';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta
			name="description"
			content="Huginn Proxy: 100% open source reverse proxy with passive TLS, HTTP/2, and TCP SYN (eBPF) fingerprints (MIT/Apache, including the signature path)."
		/>
		<title>Huginn Proxy</title>
		<link rel="icon" href={`${base}favicon.ico`} sizes="any" />
		<link rel="apple-touch-icon" sizes="180x180" href={`${base}apple-touch-icon.png`} />
		<link rel="manifest" href={`${base}site.webmanifest`} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="hp-wrap">
			<header class="hp-hero">
				<div class="hp-hero-layout">
					<div class="hp-hero-text">
						<span class="hp-badge">{releaseTag}</span>
						<h1 class="hp-title">Huginn Proxy</h1>
						<p class="hp-tagline">
							High-performance reverse proxy: passive TLS, HTTP/2, and TCP SYN (eBPF) fingerprints, injected as trusted headers for your backends.
						</p>
						<p class="hp-lede">
							<strong>100% open source.</strong> Fingerprints come from{' '}
							<a href="https://github.com/biandratti/huginn-net">Huginn Net</a>; proxy and signature path are both
							MIT/Apache. No proprietary fingerprint stack, no extra license for commercial use.
						</p>
						<div class="hp-actions">
							<a class="hp-btn hp-btn--primary" href={docs}>Documentation</a>
							<a class="hp-btn hp-btn--ghost" href={quickStart}>Quick start</a>
							<a class="hp-btn hp-btn--ghost" href={github}>GitHub</a>
						</div>
					</div>
					<div class="hp-hero-img">
						<img src={`${base}android-chrome-512x512.png`} alt="Huginn Proxy" width="280" height="280" />
					</div>
				</div>
			</header>

			<section class="hp-section" aria-labelledby="headers-heading">
				<h2 id="headers-heading">Injected fingerprint headers</h2>
				<p style="color: var(--hp-muted); margin: 0 0 1rem; max-width: 40rem;">
					Values are produced by the proxy and override any client-supplied spoofed headers.
				</p>
				<div class="hp-table-wrap">
					<table class="hp-table">
						<thead>
							<tr>
								<th scope="col">Header</th>
								<th scope="col">Layer / note</th>
							</tr>
						</thead>
						<tbody>
							<tr>
								<td><code>x-tls-ja4</code> (+ <code>-r</code> / <code>-o</code> / <code>-or</code>)</td>
								<td>TLS ClientHello: FoxIO-LLC JA4 family (hashed &amp; raw variants)</td>
							</tr>
							<tr>
								<td><code>x-tls-ja4-sv1</code> (+ <code>-sv1r</code>)</td>
								<td>TLS ClientHello: stable JA4 (ephemeral extensions excluded)</td>
							</tr>
							<tr>
								<td><code>x-http2-akamai</code></td>
								<td>HTTP/2 only</td>
							</tr>
							<tr>
								<td><code>x-tcp-p0f</code></td>
								<td>TCP SYN via eBPF (XDP or TC) when enabled</td>
							</tr>
						</tbody>
					</table>
				</div>
			</section>

			<footer class="hp-footer">
				<p>Copyright © 2025–2026 Maximiliano Biandratti</p>
				<p>
					<a href={github}>github.com/biandratti/huginn-proxy</a>
				</p>
				<p>
					Huginn Proxy is dual-licensed under the <a href={`${github}/blob/master/LICENSE-MIT`}>MIT License</a> or the
					<a href={`${github}/blob/master/LICENSE-APACHE`}>Apache License 2.0</a>, at your option.
				</p>
			</footer>
		</div>
	</body>
</html>
