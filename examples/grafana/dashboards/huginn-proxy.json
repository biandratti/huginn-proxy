        { "expr": "rate(huginn_mtls_connections_total_total[5m]) / rate(huginn_tls_handshakes_total_total[5m]) * 100", "legendFormat": "mTLS %", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 110,
      "type": "row",
