{
  "id": null,
  "uid": "huginn-proxy-overview",
  "title": "Huginn Proxy",
  "description": "Connections, requests, TLS, fingerprinting, backends, rate limiting, header manipulation, and eBPF agent.",
  "tags": ["huginn", "proxy", "fingerprinting"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    { "id": 100, "type": "row", "title": "Overview", "collapsed": false, "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 } },
    {
      "id": 1, "type": "stat", "title": "Request Rate",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rate(huginn_requests_total_total[$__rate_interval]) or on() vector(0))", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 2, "type": "stat", "title": "Active Connections",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(huginn_connections_active) or on() vector(0)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 400 }] } } }
    },
    {
      "id": 3, "type": "stat", "title": "Error Rate (5xx)",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rate(huginn_requests_total_total{status_code=~\"5..\"}[$__rate_interval]) or on() vector(0)) / sum(rate(huginn_requests_total_total[$__rate_interval]) or on() vector(1)) * 100", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 4, "type": "stat", "title": "P95 Latency",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(huginn_requests_duration_seconds_bucket[$__rate_interval])) by (le))", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 5, "type": "stat", "title": "Bandwidth In+Out",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "targets": [{ "expr": "(sum(rate(huginn_bytes_received_total_total[$__rate_interval]) or on() vector(0)) + sum(rate(huginn_bytes_sent_total_total[$__rate_interval]) or on() vector(0))) / 1024 / 1024", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "MBs", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 6, "type": "stat", "title": "Version",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "targets": [{ "expr": "huginn_build_info", "legendFormat": "v{{version}} (rust {{rust_version}})", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "textMode": "name" },
      "fieldConfig": { "defaults": {} }
    },

    { "id": 101, "type": "row", "title": "Traffic", "collapsed": false, "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 } },
    {
      "id": 7, "type": "timeseries", "title": "Request Rate by Status Code",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (status_code) (rate(huginn_requests_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "{{status_code}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 8, "type": "timeseries", "title": "Active Connections by Protocol",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        { "expr": "huginn_connections_active or on() vector(0)", "legendFormat": "{{protocol}}", "refId": "A" },
        { "expr": "huginn_tls_connections_active or on() vector(0)", "legendFormat": "TLS (total)", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 9, "type": "timeseries", "title": "Request Duration (P50 / P95 / P99)",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(huginn_requests_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(huginn_requests_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(huginn_requests_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 10, "type": "timeseries", "title": "Throughput — Client (bytes/s)",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (protocol) (rate(huginn_bytes_received_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "in — {{protocol}}", "refId": "A" },
        { "expr": "sum by (protocol) (rate(huginn_bytes_sent_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "out — {{protocol}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "description": "Only populated when requests/responses include a Content-Length header. GET requests without a body will not contribute to bytes_received."
    },
    {
      "id": 35, "type": "timeseries", "title": "Connection Rate + Rejections",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(huginn_connections_total_total[$__rate_interval]) or on() vector(0))", "legendFormat": "established", "refId": "A" },
        { "expr": "sum by (reason) (rate(huginn_connections_rejected_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "rejected — {{reason}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 36, "type": "timeseries", "title": "Timeouts by Type",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (timeout_type) (rate(huginn_timeouts_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "{{timeout_type}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    { "id": 102, "type": "row", "title": "TLS", "collapsed": false, "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 } },
    {
      "id": 11, "type": "timeseries", "title": "TLS Handshakes",
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (tls_version) (rate(huginn_tls_handshakes_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "{{tls_version}}", "refId": "A" },
        { "expr": "sum(rate(huginn_tls_handshake_errors_total_total[$__rate_interval]) or on() vector(0))", "legendFormat": "errors", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 12, "type": "timeseries", "title": "TLS Handshake Duration (P95)",
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(huginn_tls_handshake_duration_seconds_bucket[$__rate_interval])) by (le, tls_version))", "legendFormat": "P95 — {{tls_version}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    { "id": 103, "type": "row", "title": "Fingerprinting — Extraction Rate", "collapsed": false, "gridPos": { "x": 0, "y": 39, "w": 24, "h": 1 } },
    {
      "id": 13, "type": "timeseries", "title": "TLS Fingerprint (JA4)",
      "gridPos": { "x": 0, "y": 40, "w": 8, "h": 8 },
      "targets": [
        { "expr": "rate(huginn_tls_fingerprints_extracted_total_total[$__rate_interval]) or on() vector(0)", "legendFormat": "extracted", "refId": "A" },
        { "expr": "rate(huginn_tls_fingerprint_failures_total_total[$__rate_interval]) or on() vector(0)", "legendFormat": "failures", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 31, "type": "timeseries", "title": "HTTP/2 Fingerprint (Akamai)",
      "gridPos": { "x": 8, "y": 40, "w": 8, "h": 8 },
      "targets": [
        { "expr": "rate(huginn_http2_fingerprints_extracted_total_total[$__rate_interval]) or on() vector(0)", "legendFormat": "extracted", "refId": "A" },
        { "expr": "rate(huginn_http2_fingerprint_failures_total_total[$__rate_interval]) or on() vector(0)", "legendFormat": "failures (incl. HTTP/1.1)", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 14, "type": "timeseries", "title": "TCP SYN Fingerprint (eBPF)",
      "gridPos": { "x": 16, "y": 40, "w": 8, "h": 8 },
      "targets": [
        { "expr": "sum by (reason) (rate(huginn_tcp_syn_fingerprints_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "{{reason}}", "refId": "A" },
        { "expr": "rate(huginn_tcp_syn_fingerprint_failures_total_total[$__rate_interval]) or on() vector(0)", "legendFormat": "BPF map failures", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    { "id": 111, "type": "row", "title": "Fingerprinting — Extraction Duration", "collapsed": false, "gridPos": { "x": 0, "y": 48, "w": 24, "h": 1 } },
    {
      "id": 32, "type": "timeseries", "title": "TLS Fingerprint Duration (JA4)",
      "gridPos": { "x": 0, "y": 49, "w": 8, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(huginn_tls_fingerprint_extraction_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(huginn_tls_fingerprint_extraction_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(huginn_tls_fingerprint_extraction_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 33, "type": "timeseries", "title": "HTTP/2 Fingerprint Duration (Akamai)",
      "gridPos": { "x": 8, "y": 49, "w": 8, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(huginn_http2_fingerprint_extraction_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(huginn_http2_fingerprint_extraction_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(huginn_http2_fingerprint_extraction_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 34, "type": "timeseries", "title": "TCP SYN Fingerprint Duration (eBPF)",
      "gridPos": { "x": 16, "y": 49, "w": 8, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(huginn_tcp_syn_fingerprint_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(huginn_tcp_syn_fingerprint_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(huginn_tcp_syn_fingerprint_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    { "id": 104, "type": "row", "title": "Backends", "collapsed": false, "gridPos": { "x": 0, "y": 57, "w": 24, "h": 1 } },
    {
      "id": 15, "type": "timeseries", "title": "Backend Request Rate",
      "gridPos": { "x": 0, "y": 58, "w": 8, "h": 8 },
      "targets": [{ "expr": "sum by (backend_address) (rate(huginn_backend_requests_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "{{backend_address}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 16, "type": "timeseries", "title": "Backend Error Rate",
      "gridPos": { "x": 8, "y": 58, "w": 8, "h": 8 },
      "targets": [{ "expr": "sum by (backend_address) (rate(huginn_backend_errors_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "{{backend_address}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 17, "type": "timeseries", "title": "Backend Latency P95",
      "gridPos": { "x": 16, "y": 58, "w": 8, "h": 8 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (backend_address, le) (rate(huginn_backend_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "P95 — {{backend_address}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 37, "type": "timeseries", "title": "Backend Throughput (bytes/s)",
      "gridPos": { "x": 0, "y": 66, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (backend_address) (rate(huginn_backend_bytes_received_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "in — {{backend_address}}", "refId": "A" },
        { "expr": "sum by (backend_address) (rate(huginn_backend_bytes_sent_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "out — {{backend_address}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 38, "type": "timeseries", "title": "Backend Distribution (round-robin)",
      "gridPos": { "x": 12, "y": 66, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (backend) (rate(huginn_backend_selections_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "{{backend}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    { "id": 105, "type": "row", "title": "Rate Limiting", "collapsed": false, "gridPos": { "x": 0, "y": 74, "w": 24, "h": 1 } },
    {
      "id": 18, "type": "timeseries", "title": "Rate Limit Evaluation vs Rejections",
      "gridPos": { "x": 0, "y": 75, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(huginn_rate_limit_requests_total_total[$__rate_interval]) or on() vector(0))", "legendFormat": "evaluated", "refId": "A" },
        { "expr": "sum(rate(huginn_rate_limit_allowed_total_total[$__rate_interval]) or on() vector(0))", "legendFormat": "allowed", "refId": "B" },
        { "expr": "sum(rate(huginn_rate_limit_rejected_total_total[$__rate_interval]) or on() vector(0))", "legendFormat": "rejected (429)", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 19, "type": "timeseries", "title": "Rejections by Strategy",
      "gridPos": { "x": 12, "y": 75, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (strategy) (rate(huginn_rate_limit_rejected_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "{{strategy}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    { "id": 106, "type": "row", "title": "eBPF Agent", "collapsed": false, "gridPos": { "x": 0, "y": 83, "w": 24, "h": 1 } },
    {
      "id": 20, "type": "stat", "title": "Agent Up",
      "gridPos": { "x": 0, "y": 84, "w": 4, "h": 4 },
      "targets": [{ "expr": "agent_up or on() vector(0)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 39, "type": "stat", "title": "Agent Version",
      "gridPos": { "x": 4, "y": 84, "w": 4, "h": 4 },
      "targets": [{ "expr": "huginn_ebpf_agent_build_info", "legendFormat": "v{{version}} (rust {{rust_version}})", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "textMode": "name" },
      "fieldConfig": { "defaults": {} }
    },
    {
      "id": 21, "type": "timeseries", "title": "TCP SYN Captured (agent)",
      "gridPos": { "x": 8, "y": 84, "w": 8, "h": 8 },
      "targets": [{ "expr": "rate(tcp_syn_captured_total_total[$__rate_interval]) or on() vector(0)", "legendFormat": "captured/s", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 22, "type": "timeseries", "title": "TCP SYN Failures (agent)",
      "gridPos": { "x": 16, "y": 84, "w": 8, "h": 8 },
      "targets": [
        { "expr": "rate(tcp_syn_insert_failures_total_total[$__rate_interval]) or on() vector(0)", "legendFormat": "insert failures/s", "refId": "A" },
        { "expr": "rate(tcp_syn_malformed_total_total[$__rate_interval]) or on() vector(0)", "legendFormat": "malformed/s", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    { "id": 107, "type": "row", "title": "Errors", "collapsed": false, "gridPos": { "x": 0, "y": 92, "w": 24, "h": 1 } },
    {
      "id": 23, "type": "timeseries", "title": "Error Rate by Type",
      "gridPos": { "x": 0, "y": 93, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (error_type) (rate(huginn_errors_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "{{error_type}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 24, "type": "timeseries", "title": "Error Rate by Component",
      "gridPos": { "x": 12, "y": 93, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (component) (rate(huginn_errors_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "{{component}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

