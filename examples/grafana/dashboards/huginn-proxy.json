        { "expr": "rate(huginn_ip_filter_allowed_total_total[$__rate_interval]) or on() vector(0)", "legendFormat": "allowed", "refId": "B" },
        { "expr": "rate(huginn_ip_filter_denied_total_total[$__rate_interval]) or on() vector(0)", "legendFormat": "denied (403)", "refId": "C" }
