        { "expr": "histogram_quantile(0.95, sum(rate(huginn_tls_fingerprint_extraction_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(huginn_tls_fingerprint_extraction_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P99", "refId": "C" }
      ],
