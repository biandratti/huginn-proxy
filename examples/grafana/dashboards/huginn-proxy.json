      "gridPos": { "x": 0, "y": 32, "w": 8, "h": 8 },
      "targets": [
        { "expr": "rate(huginn_tls_fingerprints_extracted_total_total[5m])", "legendFormat": "extracted", "refId": "A" },
        { "expr": "rate(huginn_tls_fingerprint_failures_total_total[5m])", "legendFormat": "failures", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 31,
      "type": "timeseries",
