    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Backend Latency P95",
      "gridPos": { "x": 16, "y": 50, "w": 8, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (backend_address, le) (rate(huginn_backend_duration_seconds_bucket[5m])))", "legendFormat": "P95 — {{backend_address}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 105,
      "type": "row",
      "title": "Rate Limiting",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 58, "w": 24, "h": 1 }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Rate Limit Evaluation vs Rejections",
      "gridPos": { "x": 0, "y": 59, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(huginn_rate_limit_requests_total_total[5m]))", "legendFormat": "evaluated", "refId": "A" },
        { "expr": "sum(rate(huginn_rate_limit_allowed_total_total[5m]))", "legendFormat": "allowed", "refId": "B" },
        { "expr": "sum(rate(huginn_rate_limit_rejected_total_total[5m]))", "legendFormat": "rejected (429)", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Rejections by Strategy",
      "gridPos": { "x": 12, "y": 59, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (strategy) (rate(huginn_rate_limit_rejected_total_total[5m]))", "legendFormat": "{{strategy}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 106,
      "type": "row",
      "title": "eBPF Agent",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 67, "w": 24, "h": 1 }
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Agent Up",
      "gridPos": { "x": 0, "y": 68, "w": 4, "h": 4 },
      "targets": [{ "expr": "agent_up", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "TCP SYN Captured (agent)",
      "gridPos": { "x": 4, "y": 68, "w": 10, "h": 8 },
      "targets": [
        { "expr": "rate(tcp_syn_captured_total[5m])", "legendFormat": "captured/s", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 22,
      "type": "timeseries",
