      "id": 33,
      "type": "timeseries",
      "title": "HTTP/2 Fingerprint Duration (Akamai)",
      "gridPos": { "x": 8, "y": 41, "w": 8, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(huginn_http2_fingerprint_extraction_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(huginn_http2_fingerprint_extraction_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(huginn_http2_fingerprint_extraction_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
