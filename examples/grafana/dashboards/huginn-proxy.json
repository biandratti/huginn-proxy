      "gridPos": { "x": 8, "y": 32, "w": 8, "h": 8 },
      "targets": [
        { "expr": "rate(huginn_http2_fingerprints_extracted_total_total[5m])", "legendFormat": "extracted", "refId": "A" },
        { "expr": "rate(huginn_http2_fingerprint_failures_total_total[5m])", "legendFormat": "failures (incl. HTTP/1.1)", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "TCP SYN Fingerprint (eBPF)",
      "gridPos": { "x": 16, "y": 32, "w": 8, "h": 8 },
      "targets": [
        { "expr": "sum by (reason) (rate(huginn_tcp_syn_fingerprints_total_total[5m]))", "legendFormat": "{{reason}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 111,
      "type": "row",
      "title": "Fingerprinting — Extraction Duration",
