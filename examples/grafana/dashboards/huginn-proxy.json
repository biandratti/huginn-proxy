    {
      "id": 27, "type": "timeseries", "title": "mTLS Connections by Protocol",
      "gridPos": { "x": 0, "y": 120, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (protocol) (rate(huginn_mtls_connections_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "{{protocol}}", "refId": "A" }],
