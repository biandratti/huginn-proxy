      "title": "Backend Error Rate",
      "gridPos": { "x": 8, "y": 50, "w": 8, "h": 8 },
      "targets": [
        { "expr": "sum by (backend_address) (rate(huginn_backend_errors_total_total[5m]))", "legendFormat": "{{backend_address}}", "refId": "A" }
