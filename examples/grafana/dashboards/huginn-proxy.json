        { "expr": "sum by (context) (rate(huginn_headers_removed_total_total[$__rate_interval])) or on() vector(0)", "legendFormat": "removed — {{context}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
